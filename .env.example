# =============================================================================
# MCQ GRID Client Portal — Environment Variables
# Copy to .env.local for local development. Never commit .env.local.
# =============================================================================

# --- Stripe -------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Stripe Price IDs (from Stripe Dashboard > Products)
STRIPE_T1_PRICE_ID=price_REPLACE_ME
STRIPE_T2_PRICE_ID=price_REPLACE_ME
STRIPE_T3_PRICE_ID=price_REPLACE_ME

# Stripe Customer Portal URL (configure in Stripe Dashboard)
STRIPE_PORTAL_URL=https://billing.stripe.com/p/REPLACE_ME

# --- Firebase -----------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=REPLACE_ME
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=REPLACE_ME.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=REPLACE_ME
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=REPLACE_ME.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=REPLACE_ME
NEXT_PUBLIC_FIREBASE_APP_ID=REPLACE_ME

# Firebase Admin SDK (server-side only)
FIREBASE_ADMIN_PROJECT_ID=REPLACE_ME
FIREBASE_ADMIN_CLIENT_EMAIL=REPLACE_ME
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----\n"

# --- GRID Engine (mcq-ventures-core) ------------------------------------------
GRID_API_URL=http://localhost:8080
GRID_API_KEY=REPLACE_ME

# --- App ----------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
