# Lane 01 — Agent Creation
STRIPE_T2_PRICE_ID=price_1TbEhCRqMRBjTFnZgta1HLnW
STRIPE_T3_PRICE_ID=price_1TbEhuRqMRBjTFnZBOhh6Y2L
STRIPE_T4_PRICE_ID=price_1TbEiWRqMRBjTFnZJBHSuGiW

